{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings",
    "description": "Site-wide brand, contact, and SEO defaults."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": { "localized": true }
  },
  "attributes": {
    "name": { "type": "string", "required": true, "default": "INSPIRE AFRICA", "pluginOptions": { "i18n": { "localized": true } } },
    "legalName": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": false } } },
    "tagline": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": true } } },
    "description": { "type": "text", "required": true, "maxLength": 280, "pluginOptions": { "i18n": { "localized": true } } },
    "baseUrl": { "type": "string", "required": true, "pluginOptions": { "i18n": { "localized": false } } },
    "locale": { "type": "string", "default": "en_GB" },
    "companyNumber": { "type": "string" },
    "companyAddress": {
      "type": "component",
      "repeatable": false,
      "component": "shared.postal-address"
    },
    "contactUkPhone": { "type": "string" },
    "contactAfricaPhone": { "type": "string" },
    "contactEmail": { "type": "email" },
    "contactLegalEmail": { "type": "email" },
    "contactSpeakupEmail": { "type": "email" },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    },
    "communityBaseUrl": { "type": "string" },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "defaultOgImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "defaultSeo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
