{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "SEO",
    "icon": "search",
    "description": "Per-page SEO metadata: canonical title, description, OG image."
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": true,
      "maxLength": 70
    },
    "metaDescription": {
      "type": "text",
      "required": true,
      "maxLength": 160
    },
    "metaKeywords": {
      "type": "string"
    },
    "metaRobots": {
      "type": "string",
      "default": "index,follow"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "ogType": {
      "type": "enumeration",
      "enum": ["website", "article", "profile"],
      "default": "website"
    },
    "structuredDataJson": {
      "type": "json"
    }
  }
}
