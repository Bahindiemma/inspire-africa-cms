# ============================================================
# INSPIRE AFRICA CMS — environment variables
# Copy to `.env` and fill in. NEVER commit `.env`.
# ============================================================

# ---------- Server ----------
HOST=0.0.0.0
PORT=1337
NODE_ENV=development
# Public origin of the running Strapi instance (used by the admin UI + signed-URL builders).
PUBLIC_URL=http://localhost:1337

# Comma-separated origins allowed by CORS. Add Next.js dev + production hosts. NEVER `*`.
CORS_ORIGINS=http://localhost:3000,http://localhost:3017,https://inspire-africa-website.vercel.app

# ---------- Secrets ----------
# Generate with: openssl rand -base64 32  (one per key, comma-separated)
APP_KEYS=replaceMeKey1,replaceMeKey2,replaceMeKey3,replaceMeKey4
API_TOKEN_SALT=replaceMeWith32+RandomBytes
ADMIN_JWT_SECRET=replaceMeWith32+RandomBytes
TRANSFER_TOKEN_SALT=replaceMeWith32+RandomBytes
JWT_SECRET=replaceMeWith32+RandomBytes
ENCRYPTION_KEY=replaceMeWith32+RandomBytes

# ---------- Database ----------
# Strapi v5 officially supports: mysql | postgres | sqlite
# This project runs on MySQL 8 / MariaDB 10.11+. Create the DB with
# CHARACTER SET utf8mb4 — don't use plain `utf8` (it silently truncates
# 4-byte characters like emoji).
DATABASE_CLIENT=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=inspire_africa_cms
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# For SQLite dev only (zero-setup local boot):
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db

# For PostgreSQL (alternative — fully supported, see config/database.ts):
# DATABASE_CLIENT=postgres
# DATABASE_PORT=5432
# DATABASE_SCHEMA=public

# ---------- Keycloak (OIDC) ----------
KEYCLOAK_ENABLED=false
KEYCLOAK_ISSUER_URL=https://auth.example.com/realms/inspire-africa
KEYCLOAK_CLIENT_ID=inspire-africa-cms
KEYCLOAK_CLIENT_SECRET=replaceMe
KEYCLOAK_REDIRECT_URI=http://localhost:1337/api/auth/keycloak/callback
KEYCLOAK_SCOPES=openid profile email roles
# Map Keycloak realm role names to Strapi role machine names.
KEYCLOAK_ROLE_ADMIN=inspire-admin
KEYCLOAK_ROLE_EDITOR=inspire-editor
KEYCLOAK_ROLE_VIEWER=inspire-viewer

# ---------- Media — choose ONE provider ----------
# `local` (default in dev) | `aws-s3` | `cloudinary`
MEDIA_PROVIDER=local

# --- AWS S3 (only if MEDIA_PROVIDER=aws-s3) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
AWS_BUCKET=inspire-africa-cms-media
# Public CloudFront distribution in front of the bucket. Optional but strongly recommended.
AWS_CDN_BASE_URL=https://cdn.inspireafricans.com
AWS_S3_SIGNED_URL_EXPIRES=900
# Set to "private" for signed-URL workflow, or "public-read" for CDN+immutable cache.
AWS_S3_ACL=public-read

# --- Cloudinary (only if MEDIA_PROVIDER=cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Email (SendGrid by default) ----------
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
EMAIL_FROM_NAME=INSPIRE AFRICA
EMAIL_FROM_ADDRESS=noreply@inspireafricans.com
EMAIL_REPLY_TO=info@inspireafricans.com
# Where form submissions are sent
EMAIL_FORM_NOTIFY=info@inspireafricans.com

# ---------- Next.js revalidation webhook ----------
FRONTEND_REVALIDATE_URL=http://localhost:3000/api/revalidate
REVALIDATE_SECRET=replaceMeWith32+RandomBytes

# ---------- Public API token ----------
# Generated once in the admin UI (Settings → API Tokens). Used by the Next.js app for public reads.
# Documented in docs/api-contract.md.

# ---------- Rate-limit + abuse protection ----------
FORM_RATE_LIMIT_PER_HOUR=10
RECAPTCHA_SECRET=
